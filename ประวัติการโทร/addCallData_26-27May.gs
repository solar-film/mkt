  // วางข้อมูล GFS หลัง GFS แถวสุดท้าย
  sheet.getRange(lastGFS + 1, 1, gfsData.length, 10).setValues(gfsData);
  
  // วางข้อมูล MHL/CAR หลัง MHL/CAR แถวสุดท้าย (เลื่อนตาม GFS ที่เพิ่ม)
  var newLastMHL = lastMHL + gfsData.length;
  sheet.getRange(newLastMHL + 1, 1, mhlData.length, 10).setValues(mhlData);
  
  SpreadsheetApp.getUi().alert(
    'เสร็จแล้ว!\n' +
    'GFS: ' + gfsData.length + ' แถว (row ' + (lastGFS+1) + '–' + (lastGFS+gfsData.length) + ')\n' +
    'MHL/CAR: ' + mhlData.length + ' แถว (row ' + (newLastMHL+1) + '–' + (newLastMHL+mhlData.length) + ')'
  );
}